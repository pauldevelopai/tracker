{
  "name": "holly",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:server": "cd server && node --watch index.js",
    "dev:client": "cd client && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "migrate": "cd server && node db/migrate.js",
    "seed": "cd server && node db/seed.js",
    "build": "cd client && npm run build",
    "orchestrate": "cd server && node db/scripts/orchestrate.js",
    "scrape": "cd server && node db/scripts/scrape-only.js",
    "triage": "cd server && node db/scripts/triage-nightly.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "googleapis": "^171.4.0"
  }
}
